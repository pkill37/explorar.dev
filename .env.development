# Development Environment Variables
# This file is committed to git and provides defaults for local development

# Optional: Site URL for metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Override curated corpus fetches (`/repos/*`) to hit a remote site/bucket-backed origin
# Example: https://explorar.dev
# NEXT_PUBLIC_CURATED_CONTENT_BASE_URL=

# Direct public R2/custom-domain origin for curated corpus fetches when selecting "R2 bucket"
# Example: https://pub-<hash>.r2.dev or https://r2.explorar.dev
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://pub-fed8a8778c5340c9a70aec8e22b8296d.r2.dev
